{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }
  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<div
  id="product-reviews"
  class="color-{{ section.settings.color_scheme }} gradient product-reviews section-{{ section.id }}-padding"
  {{ section.shopify_attributes }}
>
  <div class="page-width">
    <h2 class="product-reviews__heading {{ section.settings.heading_size }}">
      {{ section.settings.heading }}
    </h2>
    <div class="product-reviews__content">
      {%- for block in section.blocks -%}
        {%- case block.type -%}
          {%- when '@app' -%}
            {% render block %}
          {%- endcase -%}
        {%- endfor -%}
      {%- comment -%}
        Judge.me: renders review widget when app is installed (populates product.metafields.judgeme.widget).
      {%- endcomment -%}
      <div id="judgeme_product_reviews" class="jdgm-widget jdgm-review-widget" data-product-title="{{ product.title | escape }}" data-id="{{ product.id }}">
        {{ product.metafields.judgeme.widget }}
      </div>
      {%- comment -%}
        Shopify Product Reviews app fallback.
      {%- endcomment -%}
      <div id="shopify-product-reviews" data-id="{{ product.id }}"></div>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Product reviews",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Customer reviews"
    },
    {
      "type": "select",
      "id": "heading_size",
      "label": "Heading size",
      "options": [
        { "value": "h2", "label": "Small" },
        { "value": "h1", "label": "Medium" },
        { "value": "h0", "label": "Large" }
      ],
      "default": "h2"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Top padding",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Bottom padding",
      "default": 36
    }
  ],
  "blocks": [
    {
      "type": "@app"
    }
  ],
  "presets": [
    {
      "name": "Product reviews"
    }
  ]
}
{% endschema %}
