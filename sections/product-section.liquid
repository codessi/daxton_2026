{% comment %}
  * on click on variant picker, the image should change to the variant image ✅
  * should be able to add mulitple variant images on the product page 
  * on click on add to cart button, the cart should add the variant to the cart
  * on click on payment button, the payment should be processed
  * on click on review button, the review should be added
  * on click on share button, the share should be shared
  * on click on related products button, the related products should be shown
  * on click on related products carousel button, the related products carousel should be shown
{% endcomment %}

{% liquid
  assign current_product = product
  assign selected_variant = current_product.selected_or_first_available_variant
  assign review_rating_data = current_product.metafields.reviews.rating.value
  assign review_rating = blank
  assign review_scale_max = 5
  if review_rating_data != blank
    assign review_rating = review_rating_data.rating | default: review_rating_data
    assign review_scale_max = review_rating_data.scale_max | default: 5
  endif
%}

{% if current_product %}
  {{ 'component-swatch.css' | asset_url | stylesheet_tag }}
  {{ 'section-product-section.css' | asset_url | stylesheet_tag }}
  {% if section.settings.show_delivery_estimate %}
    <script src="{{ 'product-delivery-estimate.js' | asset_url }}" defer="defer"></script>
  {% endif %}
  <section class="product-section-47 w-full px-4 py-4">
    <div class="mx-auto flex gap-5 max-w-[1700px]">
      <div class="desktop-only flex-1 flex flex-col gap-3 max-[80rem]:hidden">

        {% comment %} main image section: featured + variant metafield gallery (see snippet) {% endcomment %}
        <div class="test-product-main-image__wrap mx-5 ">
          {% render 'test-product-media-grid', variant: selected_variant, product: current_product %}
        </div>
        {% comment %} sku section {% endcomment %}
        <div class="product-section-47__sku">
          <span class="product-section-47__sku-label">SKU:</span>
          <span>{{ selected_variant.sku | default: 'N/A' }}</span>
        </div>
        {% comment %} description section {% endcomment %}
        {% if current_product.description != blank %}
          <div class="product-section-47__description">
            {{ current_product.description }}
          </div>
        {% endif %}
      </div>

      <div class="section-right min-w-0 self-start xl:w-[34%] sticky top-[var(--header-group-height)]">
        {% comment %} bread crumb section {% endcomment %}
        <nav class="product-section-47__breadcrumb" aria-label="Breadcrumb">
          <a href="{{ routes.root_url }}">Home</a>
          <span class="product-section-47__breadcrumb-sep" aria-hidden="true">/</span>
          {% if collection %}
            <a href="{{ collection.url }}">{{ collection.title }}</a>
          {% else %}
            <a href="{{ routes.all_products_collection_url }}">Products</a>
          {% endif %}
          <span class="product-section-47__breadcrumb-sep" aria-hidden="true">/</span>
          <span aria-current="page">{{ current_product.title }}</span>
        </nav>
        {% comment %} title section {% endcomment %}
        <h1 class="product-section-47__title">{{ current_product.title }}</h1>
        <div class="product-section-47__price-row flex justify-between">
          {% comment %} price section {% endcomment %}
          <div class="product-section-47__price">
            {{ selected_variant.price | money }}
          </div>
          {% comment %} review rating section {% endcomment %}
          <div class="product-section-47__reviews flex items-center gap-2 text-gray-700">
            {% if review_rating != blank %}
              {% assign rating_value = review_rating | round: 1 %}
              {% assign filled_stars = review_rating | round %}
              <span class="text-black">
                {% for i in (1..5) %}
                  {% if i <= filled_stars %}
                    ★
                  {% else %}
                    ☆
                  {% endif %}
                {% endfor %}
              </span>
              <span>{{ rating_value }} / {{ review_scale_max }}</span>
       
            {% endif %}
          </div>
        </div>
        {% comment %} main image section (mobile): same grid as desktop {% endcomment %}
        <div class="mobile-only xl:hidden">
          <div class="test-product-main-image__wrap mx-5 ">
            {% render 'test-product-media-grid', variant: selected_variant, product: current_product %}
          </div>
        </div>


        {% comment %} variant data section {% endcomment %}
        <script type="application/json" id="test-product-variant-data">
          {
            "variants": [
              {%- for variant in current_product.variants -%}
                {
                  "id": {{ variant.id }},
                  "option1": {{ variant.option1 | json }},
                  "option2": {{ variant.option2 | json }},
                  "option3": {{ variant.option3 | json }},
                  "image": {% assign v_img = variant.featured_image | default: current_product.featured_image %}{% if v_img %}{{ v_img | image_url: width: 1200 | json }}{% else %}null{% endif %},
                  "images": [
                    {%- liquid
                      assign v_img = variant.featured_image | default: current_product.featured_image
                      assign need_comma = false
                      if v_img
                        echo v_img | image_url: width: 1200 | json
                        assign need_comma = true
                      endif
                      assign gal = variant.metafields.custom.variant_gallery.value
                      if gal
                        for file in gal
                          if need_comma
                            echo ','
                          endif
                          if file.preview_image
                            echo file.preview_image | image_url: width: 1200 | json
                          else
                            echo file | image_url: width: 1200 | json
                          endif
                          assign need_comma = true
                        endfor
                      endif
                    -%}
                  ]
                }{%- unless forloop.last -%},{%- endunless -%}
              {%- endfor -%}
            ]
          }
        </script>

        {% comment %} form section {% endcomment %}
        {%- form 'product',
          current_product,
          id: 'test-product-form',
          class: 'flex flex-col gap-4  rounded-lg border mt-4 border-gray-200 p-4'
        -%}
          {% unless current_product.has_only_default_variant %}
            <div class="flex flex-col gap-4">
              {% for option in current_product.options_with_values %}
                <fieldset class="test-product-option-fieldset border-0 flex flex-col gap-3" data-option-name="{{ option.name | escape }}">
                  <legend class="product-section-47__option-legend">
                    {{ option.name | escape }}:
                    <span data-option-selected-value>{{ option.selected_value | escape }}</span>
                  </legend>
                  <div class="flex flex-wrap gap-2.5">
                    {% liquid
                      assign option_name_down = option.name | downcase
                    %}
                    {% for value in option.values %}
                      {% if option_name_down == 'size' %}
                        {% render 'test-product-option-button',
                          option: option,
                          value: value
                        %}
                      {% elsif option_name_down == 'color' or option_name_down == 'colour' %}
                        {% if section.settings.color_option_style == 'image' %}
                          {% render 'test-product-option-swatch',
                            product: current_product,
                            option: option,
                            value: value,
                            selected_variant: selected_variant
                          %}
                        {% else %}
                          {% render 'test-product-option-color-swatch',
                            option: option,
                            value: value,
                            swatch_shape: section.settings.color_swatch_shape
                          %}
                        {% endif %}
                      {% else %}
                        {% render 'test-product-option-swatch',
                          product: current_product,
                          option: option,
                          value: value,
                          selected_variant: selected_variant
                        %}
                      {% endif %}
                    {% endfor %}
                  </div>
                </fieldset>
              {% endfor %}
            </div>
          {% endunless %}

          <input id="test-product-variant-id" type="hidden" name="id" value="{{ selected_variant.id }}">

          <button
            type="submit"
            name="add"
            class="product-section-47__submit w-full border-0 bg-black text-white transition hover:bg-gray-800 disabled:cursor-not-allowed disabled:opacity-50"
            {% unless selected_variant.available %}
              disabled
            {% endunless %}
          >
            {% if selected_variant.available %}
              Add to cart
            {% else %}
              Sold out
            {% endif %}
          </button>

          <div class="*:w-full">
            {{ form | payment_button }}
          </div>
        {%- endform -%}
        {% comment %} delivery estimate {% endcomment %}
        {% render 'product-delivery-estimate',
          section: section,
          variant_available: selected_variant.available
        %}

        <div class="mobile-only xl:hidden flex flex-col gap-3">
          {% comment %} sku section {% endcomment %}
          <div class="product-section-47__sku">
            <span class="product-section-47__sku-label">SKU:</span>
            <span>{{ selected_variant.sku | default: 'N/A' }}</span>
          </div>
          {% comment %} description section {% endcomment %}
          {% if current_product.description != blank %}
            <div class="product-section-47__description">
              {{ current_product.description }}
            </div>
          {% endif %}
        </div>

        {% comment %} share section {% endcomment %}
        <div class="product-section-47__share flex items-center gap-3">
          <span class="product-section-47__share-label">Share:</span>
          <a
            href="https://www.facebook.com/sharer/sharer.php?u={{ shop.url | append: current_product.url | url_encode }}"
            target="_blank"
            rel="noopener noreferrer"
            class="text-blue-600 hover:underline"
          >
            Facebook
          </a>
          <a
            href="https://twitter.com/intent/tweet?url={{ shop.url | append: current_product.url | url_encode }}&text={{ current_product.title | url_encode }}"
            target="_blank"
            rel="noopener noreferrer"
            class="text-sky-500 hover:underline"
          >
            X
          </a>
          <a
            href="mailto:?subject={{ current_product.title | escape }}&body={{ shop.url | append: current_product.url }}"
            class="text-gray-700 hover:underline"
          >
            Email
          </a>
        </div>

        {% comment %} related products section {% endcomment %}
        {% if collection and collection.products_count > 1 %}
          <div class="flex flex-col gap-3">
            <h2 class="product-section-47__related-title text-gray-900">Related products</h2>
            <div class="flex gap-3 overflow-x-auto pb-2">
              {% for related_product in collection.products limit: 8 %}
                {% if related_product.id != current_product.id %}
                  <a href="{{ related_product.url }}" class="min-w-[180px] rounded border border-gray-200 p-2">
                    {% if related_product.featured_image %}
                      {{
                        related_product.featured_image
                        | image_url: width: 500
                        | image_tag: alt: related_product.title, class: 'mb-2 h-40 w-full rounded object-cover'
                      }}
                    {% endif %}
                    <p class="product-section-47__related-name line-clamp-2 text-gray-900">{{ related_product.title }}</p>
                    <p class="product-section-47__related-price mt-1 text-gray-700">{{ related_product.price | money }}</p>
                  </a>
                {% endif %}
              {% endfor %}
            </div>
          </div>
        {% endif %}

        {% comment %} reviews section {% endcomment %}
    
      </div>
    </div>
  </section>
{% else %}
  <section class="px-4 py-8 text-sm text-gray-600">Product data is unavailable in this context.</section>
{% endif %}

<script>
  (function () {
    function refreshCarouselNav(carousel) {
      if (!carousel) return;
      var track = carousel.querySelector('[data-test-product-media-grid]');
      var nav = carousel.querySelector('[data-test-carousel-nav]');
      var prev = carousel.querySelector('[data-test-carousel-prev]');
      var next = carousel.querySelector('[data-test-carousel-next]');
      if (!track || !prev || !next) return;
      var n = track.children.length;
      if (nav) nav.classList.toggle('hidden', n <= 1);
      if (n <= 1) {
        prev.disabled = true;
        next.disabled = true;
        return;
      }
      var maxScroll = Math.max(0, track.scrollWidth - track.clientWidth - 1);
      prev.disabled = track.scrollLeft <= 1;
      next.disabled = track.scrollLeft >= maxScroll;
    }

    function bindCarousels() {
      document.querySelectorAll('[data-test-product-carousel]').forEach(function (carousel) {
        if (carousel.dataset.carouselBound === '1') return;
        carousel.dataset.carouselBound = '1';
        var track = carousel.querySelector('[data-test-product-media-grid]');
        var prev = carousel.querySelector('[data-test-carousel-prev]');
        var next = carousel.querySelector('[data-test-carousel-next]');
        if (!track || !prev || !next) return;

        function slideDelta() {
          return track.clientWidth || 1;
        }

        prev.addEventListener('click', function () {
          track.scrollBy({ left: -slideDelta(), behavior: 'smooth' });
        });
        next.addEventListener('click', function () {
          track.scrollBy({ left: slideDelta(), behavior: 'smooth' });
        });
        track.addEventListener(
          'scroll',
          function () {
            refreshCarouselNav(carousel);
          },
          { passive: true }
        );
        window.addEventListener('resize', function () {
          refreshCarouselNav(carousel);
        });
        refreshCarouselNav(carousel);
      });
    }

    bindCarousels();

    (function initTestProductLightbox() {
      if (document.documentElement.dataset.testProductLightboxBound === '1') return;
      document.documentElement.dataset.testProductLightboxBound = '1';

      function closeAllLightboxes() {
        document.querySelectorAll('[data-test-product-lightbox]').forEach(function (lb) {
          lb.classList.add('hidden');
          lb.classList.remove('flex');
        });
        document.body.style.overflow = '';
      }

      document.addEventListener('click', function (e) {
        var trigger = e.target.closest('[data-test-product-zoom-trigger]');
        if (trigger) {
          var carousel = trigger.closest('[data-test-product-carousel]');
          if (!carousel) return;
          var lightbox = carousel.querySelector('[data-test-product-lightbox]') || carousel.__testProductLightbox;
          if (!lightbox) return;
          carousel.__testProductLightbox = lightbox;
          var itemsRoot = lightbox.querySelector('[data-test-product-lightbox-items]');
          if (!itemsRoot) return;
          if (!lightbox.dataset.portalMounted) {
            document.body.appendChild(lightbox);
            lightbox.dataset.portalMounted = '1';
          }
          var idx = parseInt(trigger.getAttribute('data-test-product-lightbox-index') || '0', 10);
          lightbox.classList.remove('hidden');
          lightbox.classList.add('flex');
          document.body.style.overflow = 'hidden';
          requestAnimationFrame(function () {
            requestAnimationFrame(function () {
              var item = lightbox.querySelector(
                '[data-test-product-lightbox-item][data-test-product-lightbox-index="' + idx + '"]'
              );
              if (item) item.scrollIntoView({ block: 'start', behavior: 'auto' });
            });
          });
          return;
        }

        if (e.target.closest('[data-test-product-lightbox-close]') || e.target.closest('[data-test-product-lightbox-backdrop]')) {
          var lb = e.target.closest('[data-test-product-lightbox]');
          if (lb) {
            lb.classList.add('hidden');
            lb.classList.remove('flex');
            document.body.style.overflow = '';
          }
        }
      });

      document.addEventListener('keydown', function (e) {
        if (e.key !== 'Escape') return;
        closeAllLightboxes();
      });
    })();

    var form = document.getElementById('test-product-form');
    var dataEl = document.getElementById('test-product-variant-data');
    var wraps = document.querySelectorAll('.test-product-main-image__wrap');
    if (!form || !dataEl || wraps.length === 0) return;

    var data;
    try {
      data = JSON.parse(dataEl.textContent);
    } catch (e) {
      return;
    }

    var variants = data.variants || [];

    function getSelectedOptions() {
      var fieldsets = form.querySelectorAll('fieldset');
      var result = [];
      fieldsets.forEach(function (fs) {
        var checked = fs.querySelector('input[type="radio"]:checked');
        result.push(checked ? checked.value : null);
      });
      return result;
    }

    function findVariant(selected) {
      return variants.find(function (v) {
        var o1 = selected[0] == null || v.option1 === selected[0];
        var o2 = selected[1] == null || v.option2 === selected[1];
        var o3 = selected[2] == null || v.option3 === selected[2];
        return o1 && o2 && o3;
      });
    }

    function updateOptionLabels() {
      form.querySelectorAll('fieldset.test-product-option-fieldset').forEach(function (fs) {
        var checked = fs.querySelector('input[type="radio"]:checked');
        var span = fs.querySelector('[data-option-selected-value]');
        if (span && checked) span.textContent = checked.value;
      });
    }

    function updateImageAndVariant() {
      updateOptionLabels();
      var selected = getSelectedOptions();
      var variant = findVariant(selected);
      if (!variant) return;

      var idInput = document.getElementById('test-product-variant-id');
      if (idInput) idInput.value = String(variant.id);

      var images = variant.images;
      if (!images || !images.length) {
        images = variant.image ? [variant.image] : [];
      }

      var title = '';
      var titleEl = document.querySelector('[data-test-product-media-grid][data-product-title]');
      if (titleEl) title = titleEl.getAttribute('data-product-title') || '';

      wraps.forEach(function (wrap) {
        var grid = wrap.querySelector('[data-test-product-media-grid]');
        if (!grid) return;
        if (!images.length) {
          grid.innerHTML =
            '<div class="col-span-full flex min-w-full shrink-0 snap-start lg:min-w-0 h-72 items-center justify-center rounded-lg bg-gray-100 text-sm text-gray-500">No image available</div>';
          grid.scrollLeft = 0;
          var carouselEmpty = wrap.querySelector('[data-test-product-carousel]');
          if (carouselEmpty) {
            refreshCarouselNav(carouselEmpty);
            var lbEmpty = carouselEmpty.querySelector('[data-test-product-lightbox]') || carouselEmpty.__testProductLightbox;
            var itemsEmpty = lbEmpty && lbEmpty.querySelector('[data-test-product-lightbox-items]');
            if (itemsEmpty) itemsEmpty.innerHTML = '';
          }
          return;
        }
        var safeAlt = title.replace(/"/g, '&quot;');
        function escapeAttr(s) {
          return String(s)
            .replace(/&/g, '&amp;')
            .replace(/"/g, '&quot;')
            .replace(/</g, '&lt;');
        }
        function toZoomUrl(u) {
          if (!u) return u;
          return u.replace(/([?&])width=\d+/i, '$1width=2048');
        }
        grid.innerHTML = images
          .map(function (url, idx) {
            return (
              '<div class="min-w-full w-full shrink-0 snap-start overflow-hidden rounded-lg bg-gray-100 lg:min-w-0">' +
              '<button type="button" class="block w-full cursor-zoom-in border-0 bg-transparent p-0 text-left focus:outline-none focus-visible:ring-2 focus-visible:ring-black focus-visible:ring-offset-2" data-test-product-zoom-trigger data-test-product-lightbox-index="' +
              idx +
              '" data-zoom-alt="' +
              safeAlt +
              '" aria-label="Enlarge image">' +
              '<img src="' +
              escapeAttr(url) +
              '" alt="' +
              safeAlt +
              '" class="test-product-main-image__img pointer-events-none block h-auto w-full max-w-full object-contain" loading="lazy" />' +
              '</button></div>'
            );
          })
          .join('');
        grid.scrollLeft = 0;
        var carousel = wrap.querySelector('[data-test-product-carousel]');
        if (carousel) {
          refreshCarouselNav(carousel);
          var lb = carousel.querySelector('[data-test-product-lightbox]') || carousel.__testProductLightbox;
          var itemsEl = lb && lb.querySelector('[data-test-product-lightbox-items]');
          if (itemsEl) {
            itemsEl.innerHTML = images
              .map(function (url, idx) {
                var zoomSrc = toZoomUrl(url);
                return (
                  '<div class="test-product-lightbox__item" data-test-product-lightbox-item data-test-product-lightbox-index="' +
                  idx +
                  '">' +
                  '<img src="' +
                  escapeAttr(zoomSrc) +
                  '" alt="' +
                  safeAlt +
                  '" width="2048" height="2048" class="test-product-lightbox__img mx-auto box-border block h-auto w-full max-w-none object-contain" loading="lazy" />' +
                  '</div>'
                );
              })
              .join('');
          }
        }
      });
    }

    form.addEventListener('change', function (e) {
      if (e.target && e.target.name && e.target.name.indexOf('options[') === 0) {
        updateImageAndVariant();
      }
    });
  })();
</script>

{% schema %}
{
  "name": "Test product section",
  "settings": [
    {
      "type": "header",
      "content": "Variant options"
    },
    {
      "type": "select",
      "id": "color_option_style",
      "label": "Color option display",
      "options": [
        {
          "value": "color_swatch",
          "label": "Color swatch"
        },
        {
          "value": "image",
          "label": "Variant image"
        }
      ],
      "default": "color_swatch",
      "info": "How the Color (or Colour) option is shown. Other options except Size keep variant images unless changed separately."
    },
    {
      "type": "select",
      "id": "color_swatch_shape",
      "label": "Color swatch shape",
      "options": [
        {
          "value": "circle",
          "label": "Circle"
        },
        {
          "value": "square",
          "label": "Square"
        }
      ],
      "default": "circle",
      "info": "Uses swatch colors from Shopify admin (Settings → Custom data → Products, or category metafields / Search & Discovery swatches)."
    },
    {
      "type": "header",
      "content": "Delivery estimate"
    },
    {
      "type": "checkbox",
      "id": "show_delivery_estimate",
      "label": "Show “Get it by” delivery estimate",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "delivery_start_open",
      "label": "Show ZIP code field by default",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "delivery_auto_detect_zip",
      "label": "Auto-detect visitor ZIP code",
      "default": true,
      "info": "Uses the logged-in customer address when available, otherwise estimates ZIP from the visitor’s IP (US only). Visitors can change it with the caret."
    },
    {
      "type": "text",
      "id": "delivery_default_zip",
      "label": "Default ZIP code",
      "default": "90013"
    },
    {
      "type": "range",
      "id": "delivery_processing_days",
      "min": 0,
      "max": 5,
      "step": 1,
      "label": "Processing time (business days)",
      "default": 1,
      "info": "Days to pack and ship after order."
    },
    {
      "type": "range",
      "id": "delivery_transit_days",
      "min": 1,
      "max": 10,
      "step": 1,
      "label": "Local transit time (business days)",
      "default": 2,
      "info": "Ground transit for SoCal ZIPs (900–935) after processing. Extra days apply for distant US ZIPs (ships from Los Angeles)."
    },
    {
      "type": "range",
      "id": "delivery_transit_range_days",
      "min": 0,
      "max": 5,
      "step": 1,
      "label": "Delivery date range (extra business days)",
      "default": 1,
      "info": "Adds buffer days to the latest “Get it by” date (e.g. Wed – Fri)."
    },
    {
      "type": "richtext",
      "id": "delivery_note_1",
      "label": "Delivery note 1",
      "default": "<p>FREE SHIPPING on all orders.</p>"
    },
    {
      "type": "richtext",
      "id": "delivery_note_2",
      "label": "Delivery note 2",
      "default": "<p>Orders $75+ qualify for free standard shipping.</p>"
    }
  ],
  "presets": [
    {
      "name": "Test product section"
    }
  ]
}
{% endschema %}
