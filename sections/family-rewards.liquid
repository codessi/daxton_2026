{{ 'section-family-rewards.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign benefits = section.settings.benefits_text | split: '|'
-%}

{%- style -%}
  .section-{{ section.id }}-padding .family-rewards__inner {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }
  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding .family-rewards__inner {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<div class="family-rewards color-{{ section.settings.color_scheme }} gradient section-{{ section.id }}-padding">
  <div class="family-rewards__wrap isolate w-full max-w-full px-6 md:px-10 lg:px-12 box-border">
    <div class="family-rewards__inner flex flex-wrap items-stretch gap-x-6 gap-y-4 py-4 md:py-5 md:flex-nowrap">
      <div class="family-rewards__left  border-r-2 px-4 border-black w-full min-w-0 md:w-auto md:flex-none md:flex-shrink-0 flex flex-col items-center justify-center text-center">
        {%- if section.settings.join_label != blank -%}
          <span class="font-acumin-condensed block text-black text-xs md:text-sm font-bold uppercase tracking-widest mb-0.5 leading-tight">{{ section.settings.join_label | escape }}</span>
        {%- endif -%}
        {%- if section.settings.title != blank -%}
          <h2 class="font-acumin-condensed mb-0.5 text-2xl md:text-4xl font-bold uppercase tracking-[0.18em] leading-tight">{{ section.settings.title | escape }}</h2>
        {%- endif -%}
        {%- if section.settings.cta_text != blank -%}
          <a href="{{ section.settings.cta_link | default: '#' }}" class="family-rewards__cta inline-block text-xs md:text-sm font-acumin-condensed font-semibold uppercase underline underline-offset-2 tracking-widest mt-0.5 focus-inset hover:opacity-[0.85]">
            {{ section.settings.cta_text | escape }}
          </a>
        {%- endif -%}
      </div>

      <div class=" family-rewards__right flex flex-col gap-y-6 items-center justify-center w-full min-w-0 md:flex-1 text-left">
        {%- if section.settings.benefits_headline != blank -%}
          <p class=" mb-1 text-sm md:text-lg font-normal leading-snug">{{ section.settings.benefits_headline | escape }}</p>
        {%- endif -%}
        {%- if section.settings.benefits_text != blank -%}
          <p class=" flex flex-nowrap gap-x-2 gap-y-1 family-rewards__benefits m-0 text-xs md:text-base italic font-normal leading-snug">
            {%- for benefit in benefits -%}
              {%- assign b = benefit | strip -%}
              {%- if b != blank -%}
                {%- unless forloop.first -%}<span class="family-rewards__dot mx-[0.2em] opacity-85 not-italic" aria-hidden="true">•</span>{%- endunless -%}
                {{ b }}
              {%- endif -%}
            {%- endfor -%}
          </p>
        {%- endif -%}
      </div>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Family rewards banner",
  "tag": "section",
  "class": "section section-family-rewards",
  "disabled_on": { "groups": ["header", "footer"] },
  "settings": [
    {
      "type": "header",
      "content": "Left side"
    },
    {
      "type": "text",
      "id": "join_label",
      "label": "Small label above title",
      "default": "Join the"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "Daxton Members"
    },
    {
      "type": "text",
      "id": "cta_text",
      "label": "CTA link text",
      "default": "Join for free"
    },
    {
      "type": "url",
      "id": "cta_link",
      "label": "CTA link"
    },
    {
      "type": "header",
      "content": "Right side (benefits)"
    },
    {
      "type": "text",
      "id": "benefits_headline",
      "label": "Benefits headline",
      "default": "By joining our rewards program you'll get these exclusive benefits:"
    },
    {
      "type": "textarea",
      "id": "benefits_text",
      "label": "Benefits (separate with |)",
      "default": "Free Shipping on All Orders | Earn Points for Money Off | Early Access to Sales & Drops | Save Your Teams for Personalized Shopping",
      "info": "Use | to separate each benefit. They will display with dots between."
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-2"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0, "max": 100, "step": 4, "unit": "px",
      "label": "Top padding", "default": 20
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0, "max": 100, "step": 4, "unit": "px",
      "label": "Bottom padding", "default": 20
    }
  ],
  "presets": [
    {
      "name": "Family rewards banner"
    }
  ]
}
{% endschema %}
