{%- liquid
  assign menu = section.settings.menu
  if menu == blank
    assign menu = linklists['main-menu']
  endif
  assign logo = section.settings.logo
  assign logo_height = section.settings.logo_height
  assign show_debug_borders = section.settings.show_debug_borders
-%}

<header
  class="site-header js-site-header sticky top-0 z-50  bg-white"
  style="--logo-max-height: {{ logo_height }}px;"
  {{ section.shopify_attributes }}
>
  <div class="mx-auto box-border  flex w-full max-w-350 h-25 items-center gap-3  px-4 py-3 md:gap-6 md:py-4">
    <div class="flex flex-1 items-center md:flex-none md:justify-start">
      <details class="mobile-nav group relative md:hidden">
        <summary class="flex cursor-pointer list-none items-center justify-center rounded-md p-2 text-neutral-900 hover:bg-neutral-100 [&::-webkit-details-marker]:hidden">
          <span class="sr-only">{{ 'layout.menu' | t }}</span>
          {% render 'icon', name: 'menu' %}
        </summary>
        <div class="absolute left-0 top-full z-50 mt-1 w-[min(100vw-2rem,22rem)] rounded-lg border border-neutral-200 bg-white p-4 shadow-lg">
          <nav class="tk-acumin-pro-extra-condensed box-border font-nav{% if show_debug_borders %} border-4 border-solid border-green-600{% endif %}" aria-label="{{ 'layout.menu' | t }}">
            {% if menu != blank %}
              <ul class="flex flex-col gap-1 text-base">
                {% for link in menu.links %}
                  <li>
                    <a class="block rounded px-2 py-2 text-lg font-extralight uppercase tracking-[0.12em] text-neutral-900 hover:bg-neutral-50" href="{{ link.url }}">{{ link.title | escape }}</a>
                    {% if link.links != blank %}
                      <ul class="ml-2 border-l border-neutral-100 pl-2">
                        {% for child in link.links %}
                          <li>
                            {% if child.links != blank %}
                              <p class="px-2 py-1 text-xs font-semibold uppercase tracking-wide text-neutral-500">{{ child.title | escape }}</p>
                              <ul class="mb-2">
                                {% for grand in child.links %}
                                  <li>
                                    <a class="block rounded px-2 py-1.5 text-neutral-700 hover:bg-neutral-50" href="{{ grand.url }}">{{ grand.title | escape }}</a>
                                  </li>
                                {% endfor %}
                              </ul>
                            {% else %}
                              <a class="block rounded px-2 py-1.5 text-xs font-semibold uppercase tracking-wide text-neutral-700 hover:bg-neutral-50" href="{{ child.url }}">{{ child.title | escape }}</a>
                            {% endif %}
                          </li>
                        {% endfor %}
                      </ul>
                    {% endif %}
                  </li>
                {% endfor %}
              </ul>
            {% else %}
              <p class="text-sm text-neutral-500">{{ 'layout.menu_empty' | t }}</p>
            {% endif %}
          </nav>
        </div>
      </details>

      <a href="{{ routes.root_url }}" class="flex flex-1 justify-center md:flex-none md:justify-start">
        {% if logo != blank %}
          {{
            logo
            | image_url: width: 600
            | image_tag:
              class: 'h-auto max-h-[var(--logo-max-height,48px)] w-auto max-w-[140px] object-contain md:max-w-[180px]',
              widths: '180, 360, 540',
              alt: shop.name
          }}
        {% else %}
          <span class="text-lg font-semibold tracking-tight text-neutral-900 md:text-xl">{{ shop.name }}</span>
        {% endif %}
      </a>
    </div>

    <nav
      class="tk-acumin-pro-extra-condensed font-nav flex-1 justify-start self-stretch md:items-center{% if section.settings.mega_menu_debug_pinned %} flex{% else %} hidden md:flex{% endif %}"
      aria-label="{{ 'layout.menu' | t }}"
    >
      {% if menu != blank %}
        {% liquid
          assign mega_debug_effective_handle = ''
          if section.settings.mega_menu_debug_pinned
            assign req = section.settings.mega_menu_debug_handle | strip | downcase | replace: ' ', '-'
            assign req = req | replace: '--', '-'
            assign req = req | replace: '--', '-'
            assign req = req | replace: '--', '-'
            if req != blank
              for dbg_link in menu.links
                if dbg_link.links != blank and dbg_link.handle == req
                  assign mega_debug_effective_handle = req
                  break
                endif
              endfor
            endif
            if mega_debug_effective_handle == ''
              for dbg_link in menu.links
                if dbg_link.links != blank
                  assign mega_debug_effective_handle = dbg_link.handle
                  break
                endif
              endfor
            endif
          endif
        %}
        <ul class="flex flex-wrap items-center justify-center gap-x-4 gap-y-1 lg:gap-x-2">
          {% for link in menu.links %}
            <li
              class="group relative flex items-center [&:has([data-mega-panel])]:after:absolute [&:has([data-mega-panel])]:after:left-0 [&:has([data-mega-panel])]:after:right-0 [&:has([data-mega-panel])]:after:top-full [&:has([data-mega-panel])]:after:z-[35] [&:has([data-mega-panel])]:after:block [&:has([data-mega-panel])]:after:h-8 [&:has([data-mega-panel])]:after:content-['']"
            >
              <a
                class="tk-acumin-pro-extra-condensed relative inline-flex items-center px-1 py-2 text-base font-bold uppercase text-neutral-900 after:pointer-events-none after:absolute after:bottom-0 after:left-0 after:h-[3px] after:w-full after:origin-left after:scale-x-0 after:bg-neutral-900 after:transition-transform after:duration-200 after:ease-out lg:px-2{% if show_debug_borders %} border-4 border-solid border-blue-600{% endif %}{% if link.active or link.child_active %} after:scale-x-100{% endif %} group-hover:after:scale-x-100 group-focus-within:after:scale-x-100"
                href="{{ link.url }}"
                {% if link.links != blank %}
                  aria-haspopup="true"
                {% endif %}
              >
                {{ link.title | escape }}
              </a>

              {% if link.links != blank %}
                {% liquid
                  assign mega_promo = nil
                  for block in section.blocks
                    if block.type == 'mega_menu_promo'
                      assign ph = block.settings.parent_handle | strip | downcase | replace: ' ', '-'
                      assign ph = ph | replace: '--', '-'
                      assign ph = ph | replace: '--', '-'
                      assign ph = ph | replace: '--', '-'
                      if ph == link.handle
                        assign mega_promo = block
                        break
                      endif
                    endif
                  endfor

                  assign mega_aside = false
                  assign mega_img = nil
                  assign mega_href = '#'
                  assign mega_caption = ''
                  assign mega_img_fit = section.settings.mega_menu_image_fit | default: 'contain'
                  assign mega_img_class = 'absolute inset-0 h-full w-full object-contain object-center px-4 transition duration-500 group-hover/promo:scale-[1.02] sm:px-6 lg:px-8'
                  if mega_promo != nil
                    assign mega_aside = true
                    if mega_promo.settings.image != blank
                      assign mega_img = mega_promo.settings.image
                    endif
                    assign mega_href = mega_promo.settings.link | default: '#'
                    assign mega_caption = mega_promo.settings.title
                    if mega_promo.settings.image_fit != blank
                      assign mega_img_fit = mega_promo.settings.image_fit
                    endif
                  elsif section.settings.mega_menu_feature_collection != blank
                    assign fc = section.settings.mega_menu_feature_collection
                    assign mega_aside = true
                    if fc.featured_image != blank
                      assign mega_img = fc.featured_image
                    else
                      assign fc_first = fc.products | first
                      if fc_first != blank and fc_first.featured_image != blank
                        assign mega_img = fc_first.featured_image
                      endif
                    endif
                    assign mega_href = fc.url
                    assign mega_caption = fc.title
                  endif
                  if mega_img_fit == 'cover'
                    assign mega_img_class = 'absolute inset-0 h-full w-full object-cover object-center px-4 transition duration-500 group-hover/promo:scale-[1.02] sm:px-6 lg:px-8'
                  endif

                  assign mega_debug_this = false
                  if section.settings.mega_menu_debug_pinned and link.links != blank and mega_debug_effective_handle != blank
                    if link.handle == mega_debug_effective_handle
                      assign mega_debug_this = true
                    endif
                  endif
                %}
                <div
                  class="fixed bottom-0 left-0 right-0 top-[var(--mega-menu-top,5rem)] z-40 flex min-h-0 flex-col overflow-hidden shadow-[0_12px_40px_-12px_rgba(0,0,0,0.15)] transition duration-200 ease-out{% if show_debug_borders %} border-4 border-solid border-red-300{% endif %}{% if mega_debug_this %} pointer-events-auto visible opacity-100{% else %} pointer-events-none invisible opacity-0 group-hover:pointer-events-auto group-hover:visible group-hover:opacity-100 group-focus-within:pointer-events-auto group-focus-within:visible group-focus-within:opacity-100{% endif %}"
                  data-mega-panel
                  {% if mega_debug_this %}
                    data-mega-debug-pinned
                  {% endif %}
                  role="region"
                  aria-label="{{ link.title | escape }}"
                >
                  <div class="h-2 shrink-0 pointer-events-auto" aria-hidden="true"></div>
                  <div class="flex min-h-0 min-w-0 flex-1 flex-col overflow-hidden border-t border-neutral-200 bg-white">
                    <div class="mega-menu__scroll mx-auto flex min-h-0 w-full max-w-[85rem] flex-1 flex-col overflow-y-auto overscroll-y-contain px-4 py-12 lg:px-8{% if show_debug_borders %} border-4 border-solid border-red-600{% endif %}">
                      <div class="mega-menu__layout flex w-full min-h-0 flex-col gap-0 lg:flex-row lg:items-start lg:justify-between lg:gap-12 xl:gap-16{% if show_debug_borders %} border-4 border-solid border-green-400{% endif %}">
                        <div class="mega-menu__submenu min-h-0 min-w-0 flex-1{% if show_debug_borders %} border-4 border-solid border-yellow-400{% endif %}">
                          <div class="grid w-10/12 gap-1 sm:grid-cols-2 lg:grid-cols-2 xl:grid-cols-3{% if show_debug_borders %} border-4 border-solid border-blue-600{% endif %}">
                            {% for child in link.links %}
                              <div class="mega-menu__column text-left{% if show_debug_borders %} border-4 border-solid border-red-600{% endif %}">
                                {% if child.links != blank %}
                                  <p class="mega-menu__heading tk-acumin-pro-extra-condensed text-base font-bold uppercase tracking-0 text-neutral-900">
                                    {{ child.title | escape }}
                                  </p>
                                  <ul class="mega-menu__list mt-4 space-y-2.5">
                                    {% for grand in child.links %}
                                      <li>
                                        <a class="mega-menu__link text-[0.9375rem] font-normal leading-snug text-neutral-800 transition hover:text-neutral-950" href="{{ grand.url }}">
                                          {{- grand.title | escape -}}
                                        </a>
                                      </li>
                                    {% endfor %}
                                  </ul>
                                {% else %}
                                  <a
                                    class="mega-menu__heading tk-acumin-pro-extra-condensed text-base font-bold uppercase tracking-0 text-neutral-900 no-underline transition hover:text-neutral-950"
                                    href="{{ child.url }}"
                                  >
                                    {{- child.title | escape -}}
                                  </a>
                                {% endif %}
                              </div>
                            {% endfor %}
                          </div>
                        </div>

                        {% if mega_aside %}
                          <aside
                            class="mega-menu__feature w-full max-w-[220px] shrink-0 pt-10 max-lg:mx-auto sm:max-w-[260px] md:max-w-[300px] lg:mx-0 lg:ml-auto lg:max-w-none lg:w-[min(100%,380px)] lg:pl-10 lg:pt-0 xl:w-[400px] xl:pl-12{% if show_debug_borders %} border-4 border-solid border-orange-300{% else %} border-t border-neutral-100 lg:border-l lg:border-t-0 lg:border-neutral-100{% endif %}"
                            {% if mega_promo != nil %}
                              {{ mega_promo.shopify_attributes }}
                            {% endif %}
                          >
                            <a class="group/promo block" href="{{ mega_href }}">
                              {% if mega_img != blank %}
                                <div class="mega-menu__promo-image relative aspect-[3/4] w-full overflow-hidden bg-neutral-100">
                                  {{
                                    mega_img
                                    | image_url: width: 900
                                    | image_tag:
                                      class: mega_img_class,
                                      loading: 'lazy',
                                      sizes: '(max-width: 1023px) min(72vw, 300px), 380px',
                                      widths: '400, 600, 800, 900',
                                      alt: mega_caption | escape
                                  }}
                                </div>
                              {% endif %}
                              {% if mega_caption != blank %}
                                <span class="tk-acumin-pro-extra-condensed mt-4 block text-center text-sm font-bold uppercase tracking-[0.18em] text-neutral-900 underline-offset-4 group-hover/promo:underline">
                                  {{ mega_caption | escape }}
                                </span>
                              {% endif %}
                            </a>
                          </aside>
                        {% endif %}
                      </div>
                    </div>
                  </div>
                </div>
              {% endif %}
            </li>
          {% endfor %}
        </ul>
      {% endif %}
    </nav>

    <div class="flex flex-1 items-center justify-end gap-1 md:max-w-none md:flex-none md:gap-2">
      {% if section.settings.show_search %}
        <form
          action="{{ routes.search_url }}"
          method="get"
          role="search"
          class="mr-1 hidden min-w-0 max-w-56 items-center gap-2 rounded-full border border-neutral-300 bg-white px-3 py-2 lg:flex lg:max-w-[16rem] xl:max-w-[18rem]"
        >
          <label class="sr-only" for="SiteHeaderSearchInline">{{ 'layout.search' | t }}</label>
          <input
            id="SiteHeaderSearchInline"
            class="min-w-0 flex-1 bg-transparent text-sm text-neutral-900 outline-none placeholder:text-neutral-500"
            type="search"
            name="q"
            placeholder="{{ 'layout.search_placeholder' | t }}"
            autocomplete="off"
          >
          <button type="submit" class="shrink-0 text-neutral-700 hover:text-neutral-900" aria-label="{{ 'layout.search' | t }}">
            {% render 'icon', name: 'search' %}
          </button>
        </form>
        <details class="search-pop group relative lg:hidden">
          <summary class="flex cursor-pointer list-none items-center justify-center rounded-md p-2 text-neutral-900 hover:bg-neutral-100 [&::-webkit-details-marker]:hidden">
            <span class="sr-only">{{ 'layout.search' | t }}</span>
            {% render 'icon', name: 'search' %}
          </summary>
          <div class="absolute right-0 top-full z-50 mt-2 w-[min(calc(100vw-2rem),20rem)] rounded-lg border border-neutral-200 bg-white p-3 shadow-lg">
            <form action="{{ routes.search_url }}" method="get" role="search">
              <label class="sr-only" for="SiteHeaderSearch">{{ 'layout.search' | t }}</label>
              <input
                id="SiteHeaderSearch"
                class="w-full rounded border border-neutral-300 px-3 py-2 text-sm"
                type="search"
                name="q"
                placeholder="{{ 'layout.search_placeholder' | t }}"
              >
              <button type="submit" class="mt-2 w-full rounded bg-neutral-900 px-3 py-2 text-sm font-medium text-white">
                {{ 'layout.search' | t }}
              </button>
            </form>
          </div>
        </details>
      {% endif %}

      {% if section.settings.favorite_teams_url != blank %}
        <a
          class="hidden flex-col items-center gap-0.5 rounded-md px-1 py-1.5 text-neutral-900 hover:bg-neutral-100 sm:flex"
          href="{{ section.settings.favorite_teams_url }}"
        >
          {% render 'icon', name: 'heart' %}
          <span class="text-[10px] font-semibold uppercase tracking-[0.12em]">{{ 'layout.favorite_teams' | t }}</span>
        </a>
      {% endif %}

      <a
        class="hidden flex-col items-center gap-0.5 rounded-md px-1 py-1.5 text-neutral-900 hover:bg-neutral-100 sm:flex"
        href="{{ routes.account_url }}"
      >
        <span class="sr-only">{{ 'layout.account' | t }}</span>
        {% render 'icon', name: 'user' %}
        <span class="text-[10px] font-semibold uppercase tracking-[0.12em]" aria-hidden="true">{{ 'layout.login' | t }}</span>
      </a>

      <a class="relative flex flex-col items-center gap-0.5 rounded-md px-1 py-1.5 text-neutral-900 hover:bg-neutral-100" href="{{ routes.cart_url }}">
        <span class="sr-only">{{ 'layout.cart' | t }}</span>
        <span class="relative inline-flex">
          {% render 'icon', name: 'cart' %}
          {% if cart.item_count > 0 %}
            <span class="absolute -right-1.5 -top-1 flex h-4 min-w-4 items-center justify-center rounded-full bg-neutral-900 px-1 text-[10px] font-semibold text-white">
              {{ cart.item_count }}
            </span>
          {% endif %}
        </span>
        <span class="text-[10px] font-semibold uppercase tracking-[0.12em]" aria-hidden="true">{{ 'layout.bag' | t }}</span>
      </a>
    </div>
  </div>
</header>

{% stylesheet %}
  /* Ensure debug-pinned mega panel stays visible (overrides hover-only utilities). */
  .site-header [data-mega-debug-pinned] {
    pointer-events: auto !important;
    visibility: visible !important;
    opacity: 1 !important;
  }
{% endstylesheet %}

{% javascript %}
  (function () {
    var header = document.querySelector('.js-site-header');
    if (!header) return;

    function setMegaTop() {
      var rect = header.getBoundingClientRect();
      document.documentElement.style.setProperty('--mega-menu-top', rect.bottom + 'px');
    }

    setMegaTop();
    window.addEventListener('resize', setMegaTop);
    window.addEventListener('scroll', setMegaTop, { passive: true });
    if (document.fonts && document.fonts.ready) {
      document.fonts.ready.then(setMegaTop);
    }
    document.addEventListener('shopify:section:load', setMegaTop);
  })();
{% endjavascript %}

{% schema %}
{
  "name": "Header",
  "class": "section-site-header",
  "settings": [
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo image"
    },
    {
      "type": "range",
      "id": "logo_height",
      "min": 24,
      "max": 120,
      "step": 2,
      "unit": "px",
      "label": "Logo max height",
      "default": 48
    },
    {
      "type": "link_list",
      "id": "menu",
      "label": "Main menu",
      "default": "main-menu",
      "info": "Defaults to the Main menu handle (main-menu). Create menus under Online Store -> Navigation."
    },
    {
      "type": "collection",
      "id": "mega_menu_feature_collection",
      "label": "Mega menu featured collection",
      "info": "One collection for the right column on every mega menu (uses collection image, title, and URL). Optional if you use Mega menu promo blocks instead; a block matching the parent link handle overrides this."
    },
    {
      "type": "select",
      "id": "mega_menu_image_fit",
      "label": "Mega menu image fit",
      "options": [
        { "value": "contain", "label": "Contain" },
        { "value": "cover", "label": "Cover" }
      ],
      "default": "contain",
      "info": "Default fit for mega menu promo images."
    },
    {
      "type": "checkbox",
      "id": "mega_menu_debug_pinned",
      "label": "Debug: keep mega menu open",
      "default": true,
      "info": "Pins the mega panel open (no hover) for layout/CSS debugging. Turn off before publishing."
    },
    {
      "type": "text",
      "id": "mega_menu_debug_handle",
      "label": "Debug: menu item handle to pin",
      "info": "Optional. e.g. find-your-fit or find your fit. If empty, the first top-level item with a submenu is pinned. If set but no handle matches, it falls back to that first submenu item."
    },
    {
      "type": "checkbox",
      "id": "show_debug_borders",
      "label": "Show layout debug borders",
      "default": true,
      "info": "Thick colored outlines on the mobile drawer, top nav links, and mega menu regions. Turn off for production."
    },
    {
      "type": "checkbox",
      "id": "show_search",
      "label": "Show search",
      "default": true
    },
    {
      "type": "url",
      "id": "favorite_teams_url",
      "label": "Favorite teams link",
      "info": "Optional. Shows heart icon + label on large screens."
    }
  ],
  "blocks": [
    {
      "type": "mega_menu_promo",
      "name": "Mega menu promo",
      "settings": [
        {
          "type": "text",
          "id": "parent_handle",
          "label": "Top-level menu item handle",
          "info": "Must match that menu link's handle (e.g. find-your-fit). You can paste the title with spaces (e.g. find your fit); spaces are turned into hyphens. Overrides the section's Mega menu featured collection for this item only."
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "select",
          "id": "image_fit",
          "label": "Image fit",
          "options": [
            { "value": "contain", "label": "Contain" },
            { "value": "cover", "label": "Cover" }
          ],
          "default": "contain",
          "info": "Overrides section image fit for this promo block."
        },
        {
          "type": "text",
          "id": "title",
          "label": "Caption",
          "default": "Featured collection"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        }
      ]
    }
  ],
  "presets": [{ "name": "Header" }]
}
{% endschema %}
