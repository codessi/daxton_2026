{{ 'section-shop-by.css' | asset_url | stylesheet_tag }}
{{ 'component-slider.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }
  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<div class="shop-by color-{{ section.settings.color_scheme }} gradient">
  <div class="page-width section-{{ section.id }}-padding isolate">
    <div class="shop-by__top">
      {%- unless section.settings.title == blank -%}
        <h2 class="shop-by__heading title {{ section.settings.heading_size }}">
          {{ section.settings.title | escape }}
        </h2>
      {%- endunless -%}

      <div class="shop-by__tabs">
        {%- if section.settings.tab_1_label != blank -%}
          <a
            href="{{ section.settings.tab_1_link | default: '#' }}"
            class="shop-by__tab{% if section.settings.active_tab == '1' %} is-active{% endif %}"
          >
            {{ section.settings.tab_1_label | escape }}
          </a>
        {%- endif -%}
        {%- if section.settings.tab_2_label != blank -%}
          <a
            href="{{ section.settings.tab_2_link | default: '#' }}"
            class="shop-by__tab{% if section.settings.active_tab == '2' %} is-active{% endif %}"
          >
            {{ section.settings.tab_2_label | escape }}
          </a>
        {%- endif -%}
      </div>

      <slider-component class="shop-by__slider-component slider-mobile-gutter">
        <div class="shop-by__nav slider-buttons no-js-hidden">
          <button
            type="button"
            class="slider-button slider-button--prev"
            name="previous"
            aria-label="{{ 'general.slider.previous_slide' | t }}"
            aria-controls="Slider-{{ section.id }}"
          >
            <span class="svg-wrapper">{{ 'icon-caret.svg' | inline_asset_content }}</span>
          </button>
          <button
            type="button"
            class="slider-button slider-button--next"
            name="next"
            aria-label="{{ 'general.slider.next_slide' | t }}"
            aria-controls="Slider-{{ section.id }}"
          >
            <span class="svg-wrapper">{{ 'icon-caret.svg' | inline_asset_content }}</span>
          </button>
        </div>
        <div class="shop-by__products">
          <ul
            id="Slider-{{ section.id }}"
            class="shop-by__slider slider slider--everywhere"
            role="list"
          >
            {%- for block in section.blocks -%}
              <li
                id="Slide-{{ section.id }}-{{ forloop.index }}"
                class="shop-by__slide slider__slide "
                {{ block.shopify_attributes }}
              >
                {%- if block.settings.link != blank -%}
                  <a href="{{ block.settings.link }}" class="shop-by__card focus-inset">
                {%- else -%}
                  <span class="shop-by__card">
                {%- endif -%}
                  {%- if block.settings.image != blank -%}
                    {{
                      block.settings.image
                      | image_url: width: 400
                      | image_tag:
                        loading: 'lazy',
                        widths: '160, 200, 280, 400',
                        sizes: '(min-width: 750px) 160px, 140px',
                        class: 'shop-by__card-image border bg-white ',
                        alt: block.settings.label | default: block.settings.image.alt | escape
                    }}
                  {%- else -%}
                    <span class="shop-by__card-image" style="display:block;width:100%;aspect-ratio:1;background:rgba(var(--color-foreground),0.08);"></span>
                  {%- endif -%}
                  {%- if block.settings.label != blank -%}
                    <span class="shop-by__card-label ">{{ block.settings.label | escape }}</span>
                  {%- endif -%}
                {%- if block.settings.link != blank -%}
                  </a>
                {%- else -%}
                  </span>
                {%- endif -%}
              </li>
            {%- endfor -%}
          </ul>
        </div>
      </slider-component>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Shop By",
  "tag": "section",
  "class": "section section-shop-by",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "Shop By"
    },
    {
      "type": "select",
      "id": "heading_size",
      "options": [
        { "value": "h2", "label": "Small" },
        { "value": "h1", "label": "Medium" },
        { "value": "h0", "label": "Large" }
      ],
      "default": "h1",
      "label": "Heading size"
    },
    {
      "type": "header",
      "content": "Tabs (right of heading)"
    },
    {
      "type": "text",
      "id": "tab_1_label",
      "label": "Tab 1 label",
      "default": "Headwear"
    },
    {
      "type": "url",
      "id": "tab_1_link",
      "label": "Tab 1 link"
    },
    {
      "type": "text",
      "id": "tab_2_label",
      "label": "Tab 2 label",
      "default": "Apparel"
    },
    {
      "type": "url",
      "id": "tab_2_link",
      "label": "Tab 2 link"
    },
    {
      "type": "select",
      "id": "active_tab",
      "label": "Active tab (underlined)",
      "options": [
        { "value": "1", "label": "Tab 1" },
        { "value": "2", "label": "Tab 2" }
      ],
      "default": "1"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "Section padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Top padding",
      "default": 44
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Bottom padding",
      "default": 44
    }
  ],
  "blocks": [
    {
      "type": "style",
      "name": "Style / category",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "label",
          "label": "Label",
          "info": "e.g. Clean Up, Hitch, Franchise"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Shop By",
      "blocks": [
        { "type": "style", "settings": { "label": "Clean Up" } },
        { "type": "style", "settings": { "label": "Hitch" } },
        { "type": "style", "settings": { "label": "Franchise" } },
        { "type": "style", "settings": { "label": "Trucker" } },
        { "type": "style", "settings": { "label": "Dogs" } },
        { "type": "style", "settings": { "label": "'47 Basics" } }
      ]
    }
  ]
}
{% endschema %}
