{% comment %}
  "Get it by" delivery estimate (47brand-style).
  Caret toggles ZIP input + Update only; date and notes stay visible.
  Accepts: section, variant_available
{% endcomment %}

{% if section.settings.show_delivery_estimate %}

{%- liquid
  assign default_zip = section.settings.delivery_default_zip | default: '90013'
  assign processing_days = section.settings.delivery_processing_days | default: 1
  assign transit_days = section.settings.delivery_transit_days | default: 2
  assign transit_range_days = section.settings.delivery_transit_range_days | default: 1
  assign note_1 = section.settings.delivery_note_1
  assign note_2 = section.settings.delivery_note_2
-%}

<div
  class="product-delivery-estimate rounded border border-gray-200 bg-gray-50 text-gray-800"
  data-product-delivery-estimate
  data-variant-available="{{ variant_available }}"
>
  <script type="application/json" data-delivery-config>
    {
      "defaultZip": {{ default_zip | json }},
      "processingDays": {{ processing_days }},
      "transitDays": {{ transit_days }},
      "transitRangeDays": {{ transit_range_days }},
      "country": {{ localization.country.iso_code | default: 'US' | json }},
      "locale": {{ request.locale.iso_code | append: '-' | append: localization.country.iso_code | default: 'en-US' | json }},
      "startOpen": {{ section.settings.delivery_start_open | json }},
      "autoDetectZip": {{ section.settings.delivery_auto_detect_zip | json }},
      "customerZip": {% if customer.default_address.zip != blank %}{{ customer.default_address.zip | json }}{% else %}null{% endif %},
      "invalidZipMessage": {{ 'products.product.delivery_estimate.invalid_zip' | t | json }}
    }
  </script>

  <div class="product-delivery-estimate__header flex items-center gap-2 px-4 py-3 text-gray-900">
    <span class="inline-flex h-5 w-5 shrink-0 items-center justify-center" aria-hidden="true">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="h-5 w-5">
        <path d="M3 6h11v8H3V6zm12 0h3.5L21 11v3h-3v-2H15V6zm-1 10a2 2 0 1 1-4 0 2 2 0 0 1 4 0zM5 18a2 2 0 1 1-4 0 2 2 0 0 1 4 0zm13-1H3V4h11v2h4.09L22 10.91V17h-4z"/>
      </svg>
    </span>
    <span class="min-w-0 flex-1">
      {{ 'products.product.delivery_estimate.ship_to' | t }}
      <span class="underline decoration-1 underline-offset-2" data-delivery-zip-display>{{ default_zip | escape }}</span>
    </span>
    <button
      type="button"
      class="inline-flex h-6 w-6 shrink-0 items-center justify-center border-0 bg-transparent p-0 text-gray-900 shadow-none transition hover:bg-transparent focus:outline-none focus-visible:ring-2 focus-visible:ring-black focus-visible:ring-offset-1 "
      data-delivery-zip-toggle
      aria-expanded="{% if section.settings.delivery_start_open %}true{% else %}false{% endif %}"
      aria-controls="DeliveryZipPanel-{{ section.id }}"
      aria-label="{{ 'products.product.delivery_estimate.toggle_zip' | t }}"
    >
      <span
        class="svg-wrapper inline-flex h-4 w-4 shrink-0 transition-transform duration-200 ease-out{% if section.settings.delivery_start_open %} rotate-180{% else %} rotate-0{% endif %}"
        data-delivery-caret
        aria-hidden="true"
      >
        {{- 'icon-caret.svg' | inline_asset_content -}}
      </span>
    </button>
  </div>

  <div
    id="DeliveryZipPanel-{{ section.id }}"
    class="px-4 pb-3{% unless section.settings.delivery_start_open %} hidden{% endunless %}"
    data-delivery-zip-panel
  >
    <div class="flex gap-2">
      <label class="sr-only" for="DeliveryZip-{{ section.id }}">{{ 'products.product.delivery_estimate.zip_label' | t }}</label>
      <input
        id="DeliveryZip-{{ section.id }}"
        type="text"
        inputmode="numeric"
        autocomplete="postal-code"
        maxlength="10"
        placeholder="{{ 'products.product.delivery_estimate.zip_placeholder' | t }}"
        class="min-w-0 flex-1 rounded border border-gray-300 bg-white px-3 py-2 text-gray-900 placeholder:normal-case placeholder:text-gray-400 focus:border-black focus:outline-none focus:ring-1 focus:ring-black"
        data-delivery-zip-input
        value="{{ default_zip | escape }}"
      >
      <button
        type="button"
        class="shrink-0 rounded bg-gray-200 px-4 py-2 text-gray-800 transition hover:bg-gray-300"
        data-delivery-zip-update
      >
        {{ 'products.product.delivery_estimate.update' | t }}
      </button>
    </div>
    <p class="mt-1 hidden text-xs text-red-600" data-delivery-zip-error role="alert"></p>
  </div>

  <div class="px-4 pb-4">
    {% if variant_available %}
      <p
        class="text-gray-900{% unless variant_available %} hidden{% endunless %}"
        data-delivery-estimate-row
      >
        {{ 'products.product.delivery_estimate.get_it_by' | t }}
        <span data-delivery-date>—</span>
      </p>
    {% else %}
      <p class="text-gray-500" data-delivery-unavailable>
        {{ 'products.product.delivery_estimate.unavailable' | t }}
      </p>
    {% endif %}

    {% if note_1 != blank or note_2 != blank %}
      <ul class="product-delivery-estimate__notes mt-3 list-disc space-y-1 pl-5 text-gray-700">
        {% if note_1 != blank %}
          <li>{{ note_1 }}</li>
        {% endif %}
        {% if note_2 != blank %}
          <li>{{ note_2 }}</li>
        {% endif %}
      </ul>
    {% endif %}
  </div>
</div>
{% endif %}
