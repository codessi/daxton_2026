{% comment %}
  Featured image + variant metafield gallery (grid: 1 col mobile, 2 cols md+).
  Metafield: custom.variant_gallery (List of files / images) on Variants.
{% endcomment %}

{% liquid
  assign featured = variant.featured_image | default: product.featured_image
  assign gallery = variant.metafields.custom.variant_gallery.value
%}

<div class="relative w-full" data-test-product-carousel>
  <div
    class="
      test-product-media-grid
      flex flex-row gap-0 overflow-x-auto overscroll-x-contain [-webkit-overflow-scrolling:touch]
      snap-x snap-mandatory [scrollbar-width:none] [-ms-overflow-style:none] [&::-webkit-scrollbar]:h-0 [&::-webkit-scrollbar]:w-0
      lg:grid lg:grid-cols-2 lg:gap-0 lg:overflow-visible lg:snap-none
    "
    data-test-product-media-grid
    data-product-title="{{ product.title | escape }}"
  >
  {% liquid
    assign lightbox_index = 0
  %}
  {% if featured %}
    <div class="min-w-full w-full shrink-0 snap-start overflow-hidden rounded-lg bg-gray-100 lg:min-w-0">
      <button
        type="button"
        class="block w-full  cursor-zoom-in border-0 bg-transparent p-0 text-left focus:outline-none focus-visible:ring-2 focus-visible:ring-black focus-visible:ring-offset-2"
        data-test-product-zoom-trigger
        data-test-product-lightbox-index="{{ lightbox_index }}"
        data-zoom-alt="{{ product.title | escape }}"
        aria-label="{{ 'products.product.media.open_media' | t: index: 1 }}"
      >
        {{
          featured
          | image_url: width: 1200
          | image_tag:
            alt: product.title,
            class: 'test-product-main-image__img pointer-events-none block h-auto w-full max-w-full object-contain',
            loading: 'lazy'
        }}
      </button>
    </div>
    {% assign lightbox_index = lightbox_index | plus: 1 %}
  {% endif %}
  {% if gallery != blank %}
    {% for file in gallery %}
      <div class="min-w-full w-full shrink-0 snap-start overflow-hidden rounded-lg bg-gray-100 lg:min-w-0">
        {% assign aria_media_index = lightbox_index | plus: 1 %}
        <button
          type="button"
          class="block w-full cursor-zoom-in border-0 bg-transparent p-0 text-left focus:outline-none focus-visible:ring-2 focus-visible:ring-black focus-visible:ring-offset-2"
          data-test-product-zoom-trigger
          data-test-product-lightbox-index="{{ lightbox_index }}"
          data-zoom-alt="{{ product.title | escape }}"
          aria-label="{{ 'products.product.media.open_media' | t: index: aria_media_index }}"
        >
          {% if file.preview_image %}
            {{
              file.preview_image
              | image_url: width: 1200
              | image_tag:
                alt: product.title,
                class: 'test-product-main-image__img pointer-events-none block h-auto w-full max-w-full object-contain',
                loading: 'lazy'
            }}
          {% else %}
            {{
              file
              | image_url: width: 1200
              | image_tag:
                alt: product.title,
                class: 'test-product-main-image__img pointer-events-none block h-auto w-full max-w-full object-contain',
                loading: 'lazy'
            }}
          {% endif %}
        </button>
      </div>
      {% assign lightbox_index = lightbox_index | plus: 1 %}
    {% endfor %}
  {% endif %}
  {% if featured == blank and gallery == blank %}
    <div class="col-span-full flex w-full shrink-0 snap-start lg:min-w-0 h-72 items-center justify-center rounded-lg bg-gray-100 text-sm text-gray-500">
      No image available
    </div>
  {% endif %}
  </div>

  {% comment %} Mobile-only prev/next over bottom of gallery {% endcomment %}
  <div
    class="pointer-events-none  absolute inset-x-0 bottom-6 z-10 flex justify-between px-8 gap-4 lg:hidden"
    data-test-carousel-nav
  >
    <button
      type="button"
      class="test-product-carousel__btn pointer-events-auto flex h-12 w-12 items-center justify-center rounded-full bg-white/95 text-gray-900 shadow-md ring-1 ring-black/10 transition hover:bg-white disabled:pointer-events-none disabled:opacity-35"
      data-test-carousel-prev
      aria-label="{{ 'sections.slideshow.previous_slideshow' | t }}"
    >
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="h-5 w-5" aria-hidden="true" focusable="false">
        <path fill-rule="evenodd" d="M12.79 5.23a.75.75 0 0 1-.02 1.06L8.832 10l3.938 3.71a.75.75 0 1 1-1.04 1.08l-4.5-4.25a.75.75 0 0 1 0-1.08l4.5-4.25a.75.75 0 0 1 1.06.02Z" clip-rule="evenodd" />
      </svg>
    </button>
    <button
      type="button"
      class="test-product-carousel__btn pointer-events-auto flex h-12 w-12 items-center justify-center rounded-full bg-white/95 text-gray-900 shadow-md ring-1 ring-black/10 transition hover:bg-white disabled:pointer-events-none disabled:opacity-35"
      data-test-carousel-next
      aria-label="{{ 'sections.slideshow.next_slideshow' | t }}"
    >
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="h-5 w-5" aria-hidden="true" focusable="false">
        <path fill-rule="evenodd" d="M7.21 14.77a.75.75 0 0 1 .02-1.06L11.168 10 7.23 6.29a.75.75 0 1 1 1.04-1.08l4.5 4.25a.75.75 0 0 1 0 1.08l-4.5 4.25a.75.75 0 0 1-1.06-.02Z" clip-rule="evenodd" />
      </svg>
    </button>
  </div>

  {% comment %} Full-screen zoom (one per carousel; JS opens with data-test-product-zoom-trigger) {% endcomment %}
  <div
    class="test-product-lightbox fixed inset-0 hidden h-full w-full max-w-none flex flex-col bg-black/85 p-0"
    style="z-index: 10000;"
    data-test-product-lightbox
    role="dialog"
    aria-modal="true"
    aria-label="{{ 'products.product.media.gallery_viewer' | t }}"
  >
    {% comment %} Backdrop {% endcomment %}
    <button
      type="button"
      class="absolute inset-0 cursor-default border-0 bg-transparent"
      data-test-product-lightbox-backdrop
      aria-label="{{ 'accessibility.close' | t }}"
    ></button>
    {% comment %} Close button {% endcomment %}
    <button
      type="button"
      class="fixed right-4 top-4 z-20 flex h-10 w-10 items-center justify-center rounded-full bg-white/95 text-gray-900 shadow-md ring-1 ring-black/10 transition hover:bg-white sm:right-5 sm:top-5"
      style="z-index: 10020;"
      data-test-product-lightbox-close
      aria-label="{{ 'accessibility.close' | t }}"
    >
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="h-5 w-5" aria-hidden="true">
        <path d="M6.28 5.22a.75.75 0 0 0-1.06 1.06L8.94 10l-3.72 3.72a.75.75 0 1 0 1.06 1.06L10 11.06l3.72 3.72a.75.75 0 1 0 1.06-1.06L11.06 10l3.72-3.72a.75.75 0 0 0-1.06-1.06L10 8.94 6.28 5.22Z"/>
      </svg>
    </button>
    {% comment %} Dawn-style: all media in modal; scroll vertically (see product-media-modal + product-modal.js). {% endcomment %}
    <div class="relative z-10 flex min-h-0 flex-1 flex-col overflow-hidden pt-16 sm:pt-20" data-test-product-lightbox-scroll>
      <div
        class="test-product-lightbox__items min-h-0 w-full flex-1 overflow-y-auto overflow-x-hidden overscroll-y-contain [-webkit-overflow-scrolling:touch]"
        data-test-product-lightbox-items
        tabindex="0"
      >
        {% liquid
          assign lb_i = 0
        %}
        {% if featured %}
          <div
            class="test-product-lightbox__item block"
            data-test-product-lightbox-item
            data-test-product-lightbox-index="{{ lb_i }}"
          >
            {{
              featured
              | image_url: width: 2048
              | image_tag:
                alt: product.title,
                class: 'test-product-lightbox__img mx-auto box-border block h-auto w-full max-w-none object-contain',
                loading: 'lazy',
                widths: '550, 1100, 1500, 2048',
                sizes: '100vw'
            }}
          </div>
          {% assign lb_i = lb_i | plus: 1 %}
        {% endif %}
        {% if gallery != blank %}
          {% for file in gallery %}
            {% if file.preview_image %}
              {%- assign zoom_img = file.preview_image -%}
            {% else %}
              {%- assign zoom_img = file -%}
            {% endif %}
            <div
              class="test-product-lightbox__item block"
              data-test-product-lightbox-item
              data-test-product-lightbox-index="{{ lb_i }}"
            >
              {{
                zoom_img
                | image_url: width: 2048
                | image_tag:
                  alt: product.title,
                  class: 'test-product-lightbox__img mx-auto box-border block h-auto w-full max-w-none object-contain',
                  loading: 'lazy',
                  widths: '550, 1100, 1500, 2048',
                  sizes: '100vw'
              }}
            </div>
            {% assign lb_i = lb_i | plus: 1 %}
          {% endfor %}
        {% endif %}
      </div>
    </div>
  </div>
</div>
