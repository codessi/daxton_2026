{% comment %}
  Renders a megamenu for the header.
  Every top-level link with children uses the same layout: full-viewport panel, grid of child links,
  optional featured image + link on the right (section settings below).
  Usage: {% render 'header-mega-menu', menu: header_menu, section: section %}
{% endcomment %}
{%- assign menu = menu | default: section.settings.menu -%}
{%- assign mega_featured_image = section.settings.headwear_featured_image -%}
{%- assign mega_featured_heading = section.settings.headwear_featured_heading -%}
{%- assign mega_featured_link = section.settings.headwear_featured_link -%}
<nav class="header__inline-menu{% if nav_class != blank %} {{ nav_class }}{% endif %}">
  <ul class="list-menu list-menu--inline" role="list">
    {%- for link in menu.links -%}
      <li>
        {%- if link.links != blank -%}
          <header-menu>
            {%- comment -%} header__disclosure: required by assets/details-disclosure.js (HeaderMenu). Also gets position:relative in base.css. Not replaceable with utilities alone without changing JS. {%- endcomment -%}
            <div
              id="Details-HeaderMenu-{{ forloop.index }}"
              class="header__disclosure mega-menu mega-menu--hover-only "
            >
              <div class="flex flex-wrap items-center gap-1">
                <a
                  id="HeaderMenu-{{ link.handle }}"
                  href="{{ link.url }}"
                  class="header__menu-item inline-flex items-center no-underline transition-colors focus:outline-none focus-visible:ring-2 focus-visible:ring-[rgb(var(--color-foreground))] focus-visible:ring-offset-2 focus-visible:ring-offset-[rgb(var(--color-background))]"
                  {% if link.current %}
                    aria-current="page"
                  {% endif %}
                >
                  <span
                    {% if link.child_active %}
                      class="header__active-menu-item"
                    {% endif %}
                  >
                    {{- link.title | escape -}}
                  </span>
                </a>
                {% comment %} Button section {% endcomment %}
                <button
                  type="button"
                  class="sr-only"
                  aria-expanded="false"
                  aria-controls="MegaMenu-Content-{{ forloop.index }}"
                  aria-haspopup="true"
                  aria-label="{{ 'sections.header.submenu_for' | t: title: link.title }}"
                ></button>
              </div>
              <div 
                id="MegaMenu-Content-{{ forloop.index }}"
                class=" absolute left-0 top-full  mega-menu__content z-10 box-border  w-screen max-w-[100vw] max-h-[80vh] overflow-y-auto border-0 bg-[rgb(var(--color-background))] py-8"
                tabindex="-1"
                hidden
              >
                {% comment %} <div 
                  id="MegaMenu-Content-{{ forloop.index }}"
                  class=" border-amber-400 border-4 mega-menu__content z-10 color-{{ section.settings.menu_color_scheme }} gradient motion-reduce global-settings-popup absolute left-0 top-full box-border ml-[calc(50%-50vw)] w-screen max-w-[100vw] max-h-[80vh] overflow-y-auto border-0 bg-[rgb(var(--color-background))] py-8"
                  tabindex="-1"
                  hidden
                > {% endcomment %}
                <div class="page-width box-border flex w-full flex-col items-start gap-10 lg:flex-row">
                  <div class="min-w-0 {% if mega_featured_image != blank %}shrink-0 basis-[60%]{% else %}w-full{% endif %}">
                    <ul
                      class="mega-menu__list page-width list-none
                        {% if link.levels == 1 %}
                          !block [&_.mega-menu__link]:font-normal
                        {% else %}
                          !grid !grid-cols-3 gap-x-[1.875rem] gap-y-5
                        {% endif %}
                      "
                      role="list"
                    >
                      {%- for childlink in link.links -%}
                        <li>
                          <a
                            id="HeaderMenu-{{ link.handle }}-{{ childlink.handle }}"
                            href="{{ childlink.url }}"
                            class="mega-menu__link mega-menu__link--level-2 link{% if childlink.current %} mega-menu__link--active{% endif %}"
                            {% if childlink.current %}
                              aria-current="page"
                            {% endif %}
                          >
                            {{ childlink.title | escape }}
                          </a>
                          {%- if childlink.links != blank -%}
                            <ul class="m-0 list-none p-0" role="list">
                              {%- for grandchildlink in childlink.links -%}
                                <li>
                                  <a
                                    id="HeaderMenu-{{ link.handle }}-{{ childlink.handle }}-{{ grandchildlink.handle }}"
                                    href="{{ grandchildlink.url }}"
                                    class="mega-menu__link link{% if grandchildlink.current %} mega-menu__link--active{% endif %}"
                                    {% if grandchildlink.current %}
                                      aria-current="page"
                                    {% endif %}
                                  >
                                    {{ grandchildlink.title | escape }}
                                  </a>
                                </li>
                              {%- endfor -%}
                            </ul>
                          {%- endif -%}
                        </li>
                      {%- endfor -%}
                    </ul>
                  </div>
                  {%- if mega_featured_image != blank -%}
                    <div class="flex min-w-0 shrink-0 basis-[40%] flex-col gap-3">
                      {%- if mega_featured_link != blank -%}
                        <a href="{{ mega_featured_link }}" class="flex flex-col gap-3 text-inherit no-underline">
                      {%- endif -%}
                      <div class="relative min-h-[15rem] w-60 overflow-hidden rounded-md border border-[rgba(var(--color-foreground),0.12)] bg-[rgb(var(--color-background))]">
                        {{
                          mega_featured_image
                          | image_url: width: 550
                          | image_tag:
                            loading: 'lazy',
                            widths: '400, 550, 700',
                            sizes: '(min-width: 990px) 40vw, 100vw',
                            class: 'block h-auto w-full object-cover align-middle'
                        }}
                      </div>
                      {%- if mega_featured_heading != blank -%}
                        <p class="m-0 text-[1.1em] font-bold uppercase tracking-wide text-[rgb(var(--color-foreground))]">
                          {{ mega_featured_heading | escape }}
                        </p>
                      {%- endif -%}
                      {%- if mega_featured_link != blank -%}
                        </a>
                      {%- endif -%}
                    </div>
                  {%- endif -%}
                </div>
              </div>
            </div>
          </header-menu>
        {%- else -%}
          {%- comment -%}
            Same row + link styling as mega parents (lines 22–38), without header-menu, panel, or submenu button.
            Leaf items stay a normal link only — no button (nothing to toggle).
          {%- endcomment -%}
          <div class="flex flex-wrap items-center gap-1">
            <a
              id="HeaderMenu-{{ link.handle }}"
              href="{{ link.url }}"
              class="header__menu-item inline-flex items-center no-underline transition-colors focus:outline-none focus-visible:ring-2 focus-visible:ring-[rgb(var(--color-foreground))] focus-visible:ring-offset-2 focus-visible:ring-offset-[rgb(var(--color-background))]"
              {% if link.current %}
                aria-current="page"
              {% endif %}
            >
              <span
                {% if link.current %}
                  class="header__active-menu-item"
                {% endif %}
              >
                {{- link.title | escape -}}
              </span>
            </a>
          </div>
        {%- endif -%}
      </li>
    {%- endfor -%}
  </ul>
</nav>
