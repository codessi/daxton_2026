{% comment %}
  Renders a megamenu for the header.
  Usage: {% render 'header-mega-menu', menu: header_menu, section: section %}
  Falls back to section.settings.menu when menu param is not passed.
{% endcomment %}
{%- assign menu = menu | default: section.settings.menu -%}
<nav class="header__inline-menu">
 
  <ul class="list-menu list-menu--inline" role="list">
    {%- for link in menu.links -%}
      <li class="">

          <header-menu>

            <details id="Details-HeaderMenu-{{ forloop.index }}" class="mega-menu mega-menu--hover-only">
              <summary
                id="HeaderMenu-{{ link.handle }}"
                class="header__menu-item list-menu__item link focus-inset"
                aria-haspopup="true"
                aria-expanded="false">
          
                {%- if link.url != blank -%}
                  <a href="{{ link.url }}" class="no-underline link focus-inset ">
                    {{- link.title | escape -}}
                  </a>
             
                {%- endif -%}
              </summary>
           
         
              <div
                id="MegaMenu-Content-{{ forloop.index }}"
                class="mega-menu__content color-{{ section.settings.menu_color_scheme }} gradient motion-reduce global-settings-popup"
                tabindex="-1">
                {%- liquid
                  assign mega_promo = nil

                  for block in section.blocks
                    if block.type == 'mega_menu_promo'
                      assign ph = block.settings.parent_handle | strip | downcase | replace: ' ', '-'
                      assign ph = ph | replace: '--', '-'
                      assign ph = ph | replace: '--', '-'
                      assign ph = ph | replace: '--', '-'

                      if ph != blank and ph == link.handle
                        assign mega_promo = block
                        break
                      endif
                    endif
                  endfor

                  assign mega_img = nil
                  assign mega_heading = ''
                  assign mega_link = blank

                  if mega_promo != nil
                    assign mega_img = mega_promo.settings.image
                    assign mega_heading = mega_promo.settings.title
                    assign mega_link = mega_promo.settings.link
                  elsif link.handle == 'headwear'
                    assign mega_img = section.settings.headwear_featured_image
                    assign mega_heading = section.settings.headwear_featured_heading
                    assign mega_link = section.settings.headwear_featured_link
                  endif
                -%}
                <div class="mega-menu__content-inner page-width">
                  <div class="mega-menu__content-nav">
                    <ul
                      class="mega-menu__list{% if link.levels == 1 %} mega-menu__list--condensed list-none{% else %} grid grid-cols-[repeat(3,minmax(0,1fr))] gap-x-[2.5rem] gap-y-[1.125rem] list-none{% endif %}"
                      role="list"
                    >
                      {%- for childlink in link.links -%}
                        <li>
                          <a
                            id="HeaderMenu-{{ link.handle }}-{{ childlink.handle }}"
                            href="{{ childlink.url }}"
                            class="mega-menu__link mega-menu__link--level-2 link{% if childlink.current %} mega-menu__link--active{% endif %}"
                            {% if childlink.current %}
                            aria-current="page"
                            {% endif %}>
                            {{ childlink.title | escape }}
                          </a>
                          {%- if childlink.links != blank -%}
                            <ul class="list-unstyled" role="list">
                              {%- for grandchildlink in childlink.links -%}
                                <li>
                                  <a
                                    id="HeaderMenu-{{ link.handle }}-{{ childlink.handle }}-{{ grandchildlink.handle }}"
                                    href="{{ grandchildlink.url }}"
                                    class="mega-menu__link link{% if grandchildlink.current %} mega-menu__link--active{% endif %}"
                                    {% if grandchildlink.current %}
                                    aria-current="page"
                                    {% endif %}>
                                    {{ grandchildlink.title | escape }}
                                  </a>
                                </li>
                              {%- endfor -%}
                            </ul>
                          {%- endif -%}
                        </li>
                      {%- endfor -%}
                    </ul>
                  </div>

                  {%- if mega_img != blank or mega_heading != blank or mega_link != blank -%}
                    <div class="mega-menu__content-featured">
                      {%- if mega_link != blank -%}
                        <a href="{{ mega_link }}" class="mega-menu__featured-link">
                      {%- endif -%}

                      {%- if mega_img != blank -%}
                        <div class="mega-menu__featured-media media global-media-settings">
                          {{
                            mega_img
                            | image_url: width: 550
                            | image_tag:
                              loading: 'lazy',
                              widths: '400, 550, 700',
                              sizes: '(min-width: 990px) 40vw, 100vw',
                              class: 'mega-menu__featured-image'
                          }}
                        </div>
                      {%- endif -%}

                      {%- if mega_heading != blank -%}
                        <p class="mega-menu__featured-heading">{{ mega_heading | escape }}</p>
                      {%- endif -%}

                      {%- if mega_link != blank -%}
                        </a>
                      {%- endif -%}
                    </div>
                  {%- endif -%}
                </div>
              </div>
            </details>
          </header-menu>

      </li>
    {%- endfor -%}
  </ul>
</nav>